generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  clerkId           String             @unique
  email             String             @unique
  name              String?
  plan              Plan               @default(FREE)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  dailyUsage        DailyUsage[]
  grammarSessions   GrammarSession[]
  listeningSessions ListeningSession[]
  oralExams         OralExam[]
  paperSubmissions  PaperSubmission[]
  savedWords        SavedWord[]
  subscription      Subscription?
  vocabularyLists   VocabularyList[]
  writtenExams      WrittenExam[]

  @@index([clerkId])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 Plan               @default(FREE)
  status               SubscriptionStatus @default(INACTIVE)
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
}

model WrittenExam {
  id               String            @id @default(cuid())
  userId           String
  level            ExamLevel
  content          Json
  status           ExamStatus        @default(IN_PROGRESS)
  score            Float?
  /** Soft-delete: hidden from the user's lists but kept in the database. */
  hiddenAt         DateTime?
  startedAt        DateTime          @default(now())
  completedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  paperSubmissions PaperSubmission[]
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses        WrittenResponse[]

  @@index([userId, createdAt])
}

model WrittenResponse {
  id         String          @id @default(cuid())
  examId     String
  taskType   WrittenTaskType
  taskNumber Int
  response   String
  aiFeedback String?
  score      Float?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  exam       WrittenExam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
}

model OralExam {
  id           String         @id @default(cuid())
  userId       String
  level        ExamLevel
  status       ExamStatus     @default(IN_PROGRESS)
  overallScore Float?
  /** Ordered list of tasks user opted into for this session, e.g. ["TOPIC","CONVERSATION","LISTENING"]. */
  selectedTasks String[]      @default([])
  /** Free-form bullet points / general outline candidate prepared for the Topic task. */
  topicGeneral  String?       @db.Text
  /** Full detailed essay candidate prepared for the Topic task. */
  topicDetailed String?       @db.Text
  /** Soft-delete: hidden from the user's lists but kept in the database. */
  hiddenAt     DateTime?
  startedAt    DateTime       @default(now())
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  exchanges    OralExchange[]
  feedback     OralFeedback[]

  @@index([userId, createdAt])
}

model OralExchange {
  id        String       @id @default(cuid())
  examId    String
  taskType  OralTaskType
  role      Role
  content   String
  audioUrl  String?
  order     Int
  createdAt DateTime     @default(now())
  exam      OralExam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
}

model OralFeedback {
  id        String       @id @default(cuid())
  examId    String
  taskType  OralTaskType
  feedback  Json
  score     Float?
  createdAt DateTime     @default(now())
  exam      OralExam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
}

model ListeningSession {
  id              String     @id @default(cuid())
  userId          String
  level           ExamLevel
  status          ExamStatus @default(IN_PROGRESS)
  passageText     String
  passageTitle    String
  passageTopic    String
  round1Response  String?
  round1Feedback  Json?
  round1Score     Float?
  round2Response  String?
  round2Feedback  Json?
  round2Score     Float?
  overallScore    Float?
  startedAt       DateTime   @default(now())
  completedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  informationType String     @default("")
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GrammarSession {
  id           String    @id @default(cuid())
  userId       String
  cefrLevel    String
  exerciseType String
  questions    Json
  responses    Json?
  feedback     Json?
  score        Int?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VocabularyList {
  id        String      @id @default(cuid())
  userId    String
  name      String
  emoji     String      @default("📚")
  color     String      @default("blue")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  words     SavedWord[]
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SavedWord {
  id           String          @id @default(cuid())
  userId       String
  listId       String?
  english      String
  spanish      String
  example      String
  partOfSpeech String?
  level        String
  notes        String?
  createdAt    DateTime        @default(now())
  list         VocabularyList? @relation(fields: [listId], references: [id])
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, english])
  @@index([userId])
  @@index([listId])
}

model PaperSubmission {
  id        String      @id @default(cuid())
  userId    String
  examId    String
  level     ExamLevel
  feedback  Json?
  score     Float?
  status    String      @default("PENDING")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  exam      WrittenExam @relation(fields: [examId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([examId])
}

model DailyUsage {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime @db.Date
  writtenCount   Int      @default(0)
  oralCount      Int      @default(0)
  listeningCount Int      @default(0)
  chatCount      Int      @default(0)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model Feedback {
  id         String           @id @default(cuid())
  category   FeedbackCategory
  message    String           @db.Text
  isRead     Boolean          @default(false)
  userAgent  String?
  ipHash     String?
  createdAt  DateTime         @default(now())

  @@index([createdAt])
  @@index([isRead])
  @@index([ipHash, createdAt])
}

/// Stripe webhook events already processed, for idempotent delivery handling.
model ProcessedWebhookEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

enum FeedbackCategory {
  SUGGESTION
  BUG
  OTHER
}

enum Plan {
  FREE
  PRO
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
}

enum ExamLevel {
  ISE_FOUNDATION
  ISE_I
  ISE_II
  ISE_III
  ISE_IV
}

enum ExamStatus {
  IN_PROGRESS
  COMPLETED
  EVALUATED
}

enum WrittenTaskType {
  READING_1
  READING_2
  READING_INTO_WRITING
  EXTENDED_WRITING
}

enum OralTaskType {
  TOPIC
  COLLABORATIVE
  CONVERSATION
  LISTENING
}

enum Role {
  EXAMINER
  CANDIDATE
}
